@model ECommerceApp.Models.Product

@{
    ViewData["Title"] = "Detail Produk";
}

<div class="container mt-4">
    <div class="card shadow border-0 mt-4 mb-4">
        <div class="card-header bg-secondary bg-gradient text-light py-4">
            <div class="row">
                <div class="col-12 text-center">
                    <h3 class="text-white text-uppercase">@Model.Name</h3>
                    <p class="text-white-50 fw-semibold mb-0">Kategori: @Model.Category.Name</p>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="py-3">
                <div class="row">
                    <div class="col-12 col-lg-8 offset-lg-2 text-center">
                        <h4 class="text-dark">Harga: <span class="text-warning">Rp @Model.Price.ToString("N0")</span></h4>
                        <p class="text-secondary mt-3">@Model.Description</p>
                        
                        <div class="row mt-4">
                            <div class="col-12 col-md-6 pb-1">
                                <a asp-action="Index" class="btn btn-success bg-gradient w-100 py-2 text-uppercase fw-semibold">
                                    Kembali ke Belanja
                                </a>
                            </div>
                            <div class="col-12 col-md-6 pb-1">
                                <button type="submit" class="btn btn-primary bg-gradient w-100 py-2 text-uppercase fw-semibold disabled">
                                    Tambah ke Keranjang
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>